<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions expressionLanguage="https://www.omg.org/spec/DMN/20191111/FEEL/" id="definitions_Event_Action_Decision" name="Event Action Decision" namespace="https://poc.ruleengine.com" typeLanguage="https://www.omg.org/spec/DMN/20191111/FEEL/" xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/">
  <itemDefinition id="itemDef_UserProfile" name="UserProfile">
    <itemComponent id="ic_age" name="age">
      <typeRef>number</typeRef>
    </itemComponent>
    <itemComponent id="ic_accountType" name="accountType">
      <typeRef>string</typeRef>
    </itemComponent>
    <itemComponent id="ic_segmentType" name="segmentType">
      <typeRef>string</typeRef>
    </itemComponent>
  </itemDefinition>
  <itemDefinition id="itemDef_EventRequest" name="EventRequest">
    <itemComponent id="ic_eventName" name="eventName">
      <typeRef>string</typeRef>
    </itemComponent>
    <itemComponent id="ic_applicationCode" name="applicationCode">
      <typeRef>string</typeRef>
    </itemComponent>
    <itemComponent id="ic_userProfile" name="userProfile">
      <typeRef>UserProfile</typeRef>
    </itemComponent>
  </itemDefinition>
  <inputData id="inputData_eventRequest" name="eventRequest">
    <variable id="var_eventRequest" name="eventRequest" typeRef="EventRequest"/>
  </inputData>
  <decision id="decision_eventMatch" name="eventMatch">
    <variable id="var_eventMatch" name="eventMatch" typeRef="boolean"/>
    <informationRequirement id="_706a1eb6">
      <requiredInput href="#inputData_eventRequest"/>
    </informationRequirement>
    <decisionTable hitPolicy="FIRST" id="dt_eventMatch">
      <input id="_e709bf0e" label="Application Code">
        <inputExpression id="_ac5d0f3a" typeRef="string">
          <text>eventRequest.applicationCode</text>
        </inputExpression>
      </input>
      <input id="_cd2d9fe0" label="Event Name">
        <inputExpression id="_4a288c9f" typeRef="string">
          <text>eventRequest.eventName</text>
        </inputExpression>
      </input>
      <output id="_b8e33dd6" name="eventMatch" typeRef="boolean"/>
      <rule id="_eda2e6bf">
        <description>Match ANL OpenAccount event</description>
        <inputEntry id="_38085876">
          <text>"ANL"</text>
        </inputEntry>
        <inputEntry id="_c6a6b24e">
          <text>"OpenAccount"</text>
        </inputEntry>
        <outputEntry id="_715a178e">
          <text>true</text>
        </outputEntry>
      </rule>
      <rule id="_90b39bdb">
        <description>No match for any other event</description>
        <inputEntry id="_966acf52">
          <text>-</text>
        </inputEntry>
        <inputEntry id="_f61effe3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="_63365615">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision id="decision_userProfileMatch" name="userProfileMatch">
    <variable id="var_userProfileMatch" name="userProfileMatch" typeRef="boolean"/>
    <informationRequirement id="_9dac125f">
      <requiredInput href="#inputData_eventRequest"/>
    </informationRequirement>
    <decisionTable hitPolicy="FIRST" id="dt_userProfileMatch">
      <input id="_908645f1" label="Age">
        <inputExpression id="_20a9a82b" typeRef="number">
          <text>eventRequest.userProfile.age</text>
        </inputExpression>
      </input>
      <input id="_ecb660da" label="Account Type">
        <inputExpression id="_db79ee82" typeRef="string">
          <text>eventRequest.userProfile.accountType</text>
        </inputExpression>
      </input>
      <input id="_7edeb022" label="Segment Type">
        <inputExpression id="_7d75bbcc" typeRef="string">
          <text>eventRequest.userProfile.segmentType</text>
        </inputExpression>
      </input>
      <output id="_4b82548d" name="userProfileMatch" typeRef="boolean"/>
      <rule id="_a0d96344">
        <description>Advised OW account holder between 18 and 65</description>
        <inputEntry id="_be9e9788">
          <text>(18..65)</text>
        </inputEntry>
        <inputEntry id="_8f0a447b">
          <text>"OW"</text>
        </inputEntry>
        <inputEntry id="_6b594af1">
          <text>"Advised"</text>
        </inputEntry>
        <outputEntry id="_f62be2f9">
          <text>true</text>
        </outputEntry>
      </rule>
      <rule id="_88c86f10">
        <description>No match for other profiles</description>
        <inputEntry id="_6bcca34c">
          <text>-</text>
        </inputEntry>
        <inputEntry id="_2ddc304b">
          <text>-</text>
        </inputEntry>
        <inputEntry id="_69a33be2">
          <text>-</text>
        </inputEntry>
        <outputEntry id="_72e3713b">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision id="decision_Action_Decision" name="Action Decision">
    <variable id="var_Action_Decision" name="action" typeRef="string"/>
    <informationRequirement id="_7f7568b9">
      <requiredDecision href="#decision_eventMatch"/>
    </informationRequirement>
    <informationRequirement id="_f5b1d756">
      <requiredDecision href="#decision_userProfileMatch"/>
    </informationRequirement>
    <decisionTable hitPolicy="FIRST" id="dt_Action_Decision">
      <input id="_df31dba6" label="Event Match">
        <inputExpression id="_c47e836d" typeRef="boolean">
          <text>eventMatch</text>
        </inputExpression>
      </input>
      <input id="_c135a567" label="User Profile Match">
        <inputExpression id="_a1d83ed6" typeRef="boolean">
          <text>userProfileMatch</text>
        </inputExpression>
      </input>
      <output id="_021cdcab" name="action" typeRef="string"/>
      <rule id="_563834e0">
        <description>Both event and profile match - send SMS</description>
        <inputEntry id="_43d64321">
          <text>true</text>
        </inputEntry>
        <inputEntry id="_30ecfd8c">
          <text>true</text>
        </inputEntry>
        <outputEntry id="_b5bb7e9d">
          <text>"SendSMS"</text>
        </outputEntry>
      </rule>
      <rule id="_9726fc53">
        <description>Any other combination - do not send</description>
        <inputEntry id="_e87fa852">
          <text>-</text>
        </inputEntry>
        <inputEntry id="_62179bff">
          <text>-</text>
        </inputEntry>
        <outputEntry id="_20b0f1bd">
          <text>"NoSend"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
