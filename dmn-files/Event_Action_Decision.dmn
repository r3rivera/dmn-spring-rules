<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions expressionLanguage="https://www.omg.org/spec/DMN/20191111/FEEL/" id="definitions_Event_Action_Decision" name="Event Action Decision" namespace="https://poc.ruleengine.com" typeLanguage="https://www.omg.org/spec/DMN/20191111/FEEL/" xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/">
  <itemDefinition id="itemDef_UserProfile" name="UserProfile">
    <itemComponent id="ic_age" name="age">
      <typeRef>number</typeRef>
    </itemComponent>
    <itemComponent id="ic_accountType" name="accountType">
      <typeRef>string</typeRef>
    </itemComponent>
    <itemComponent id="ic_segmentType" name="segmentType">
      <typeRef>string</typeRef>
    </itemComponent>
  </itemDefinition>
  <itemDefinition id="itemDef_EventRequest" name="EventRequest">
    <itemComponent id="ic_eventName" name="eventName">
      <typeRef>string</typeRef>
    </itemComponent>
    <itemComponent id="ic_applicationCode" name="applicationCode">
      <typeRef>string</typeRef>
    </itemComponent>
    <itemComponent id="ic_userProfile" name="userProfile">
      <typeRef>UserProfile</typeRef>
    </itemComponent>
  </itemDefinition>
  <inputData id="inputData_eventRequest" name="eventRequest">
    <variable id="var_eventRequest" name="eventRequest" typeRef="EventRequest"/>
  </inputData>
  <decision id="decision_eventMatch" name="eventMatch">
    <variable id="var_eventMatch" name="eventMatch" typeRef="boolean"/>
    <informationRequirement id="_de9188c0">
      <requiredInput href="#inputData_eventRequest"/>
    </informationRequirement>
    <decisionTable hitPolicy="FIRST" id="dt_eventMatch">
      <input id="_300e78c7" label="Application Code">
        <inputExpression id="_246219e6" typeRef="string">
          <text>eventRequest.applicationCode</text>
        </inputExpression>
      </input>
      <input id="_cbcd6683" label="Event Name">
        <inputExpression id="_b598b901" typeRef="string">
          <text>eventRequest.eventName</text>
        </inputExpression>
      </input>
      <output id="_a5796593" name="eventMatch" typeRef="boolean"/>
      <rule id="_05ba7292">
        <description>Match ANL OpenAccount event</description>
        <inputEntry id="_a5e73af5">
          <text>"ANL"</text>
        </inputEntry>
        <inputEntry id="_efcc46dc">
          <text>"OpenAccount"</text>
        </inputEntry>
        <outputEntry id="_05486d07">
          <text>true</text>
        </outputEntry>
      </rule>
      <rule id="_cdef6e47">
        <description>No match for any other event</description>
        <inputEntry id="_67397ceb">
          <text>-</text>
        </inputEntry>
        <inputEntry id="_d137bc73">
          <text>-</text>
        </inputEntry>
        <outputEntry id="_2ff8461e">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision id="decision_userProfileMatch" name="userProfileMatch">
    <variable id="var_userProfileMatch" name="userProfileMatch" typeRef="boolean"/>
    <informationRequirement id="_a46e15e3">
      <requiredInput href="#inputData_eventRequest"/>
    </informationRequirement>
    <decisionTable hitPolicy="FIRST" id="dt_userProfileMatch">
      <input id="_dd964c26" label="Age">
        <inputExpression id="_fe44eb92" typeRef="number">
          <text>eventRequest.userProfile.age</text>
        </inputExpression>
      </input>
      <input id="_bc0a7d47" label="Account Type">
        <inputExpression id="_33395b22" typeRef="string">
          <text>eventRequest.userProfile.accountType</text>
        </inputExpression>
      </input>
      <input id="_20910f7d" label="Segment Type">
        <inputExpression id="_33b83194" typeRef="string">
          <text>eventRequest.userProfile.segmentType</text>
        </inputExpression>
      </input>
      <output id="_f4cb761c" name="userProfileMatch" typeRef="boolean"/>
      <rule id="_9cd9708a">
        <description>Advised OW account holder between 18 and 65</description>
        <inputEntry id="_2ec99cfb">
          <text>(18..65)</text>
        </inputEntry>
        <inputEntry id="_6275b3a1">
          <text>"OW"</text>
        </inputEntry>
        <inputEntry id="_bb3df01b">
          <text>"Advised"</text>
        </inputEntry>
        <outputEntry id="_41eec939">
          <text>true</text>
        </outputEntry>
      </rule>
      <rule id="_b7a78fc9">
        <description>No match for other profiles</description>
        <inputEntry id="_3f5d967f">
          <text>-</text>
        </inputEntry>
        <inputEntry id="_397f377f">
          <text>-</text>
        </inputEntry>
        <inputEntry id="_727fff32">
          <text>-</text>
        </inputEntry>
        <outputEntry id="_d15d77fa">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision id="decision_Action_Decision" name="Action Decision">
    <variable id="var_Action_Decision" name="action" typeRef="string"/>
    <informationRequirement id="_cd034758">
      <requiredDecision href="#decision_eventMatch"/>
    </informationRequirement>
    <informationRequirement id="_e5887e1d">
      <requiredDecision href="#decision_userProfileMatch"/>
    </informationRequirement>
    <decisionTable hitPolicy="FIRST" id="dt_Action_Decision">
      <input id="_1a68743b" label="Event Match">
        <inputExpression id="_12a33172" typeRef="boolean">
          <text>eventMatch</text>
        </inputExpression>
      </input>
      <input id="_7c1dd759" label="User Profile Match">
        <inputExpression id="_c7c777cd" typeRef="boolean">
          <text>userProfileMatch</text>
        </inputExpression>
      </input>
      <output id="_00347d0d" name="action" typeRef="string"/>
      <rule id="_23c9682b">
        <description>Both event and profile match - send SMS</description>
        <inputEntry id="_94b8256a">
          <text>true</text>
        </inputEntry>
        <inputEntry id="_8efe0b95">
          <text>true</text>
        </inputEntry>
        <outputEntry id="_3439faeb">
          <text>"SendSMS"</text>
        </outputEntry>
      </rule>
      <rule id="_7d17f08d">
        <description>Any other combination - do not send</description>
        <inputEntry id="_bc30b856">
          <text>-</text>
        </inputEntry>
        <inputEntry id="_efc24107">
          <text>-</text>
        </inputEntry>
        <outputEntry id="_dc6c774b">
          <text>"NoSend"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
