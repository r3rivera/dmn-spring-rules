<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions expressionLanguage="https://www.omg.org/spec/DMN/20191111/FEEL/" id="definitions_Event_Action_Decision" name="Event Action Decision" namespace="https://poc.ruleengine.com" typeLanguage="https://www.omg.org/spec/DMN/20191111/FEEL/" xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/">
  <itemDefinition id="itemDef_UserProfile" name="UserProfile">
    <itemComponent id="ic_age" name="age">
      <typeRef>number</typeRef>
    </itemComponent>
    <itemComponent id="ic_accountType" name="accountType">
      <typeRef>string</typeRef>
    </itemComponent>
    <itemComponent id="ic_segmentType" name="segmentType">
      <typeRef>string</typeRef>
    </itemComponent>
  </itemDefinition>
  <itemDefinition id="itemDef_EventRequest" name="EventRequest">
    <itemComponent id="ic_eventName" name="eventName">
      <typeRef>string</typeRef>
    </itemComponent>
    <itemComponent id="ic_applicationCode" name="applicationCode">
      <typeRef>string</typeRef>
    </itemComponent>
    <itemComponent id="ic_userProfile" name="userProfile">
      <typeRef>UserProfile</typeRef>
    </itemComponent>
  </itemDefinition>
  <inputData id="inputData_eventRequest" name="eventRequest">
    <variable id="var_eventRequest" name="eventRequest" typeRef="EventRequest"/>
  </inputData>
  <decision id="decision_eventMatch" name="eventMatch">
    <variable id="var_eventMatch" name="eventMatch" typeRef="boolean"/>
    <informationRequirement id="_2b2feb8c">
      <requiredInput href="#inputData_eventRequest"/>
    </informationRequirement>
    <decisionTable hitPolicy="FIRST" id="dt_eventMatch">
      <input id="_a794d161" label="Application Code">
        <inputExpression id="_9a4842ef" typeRef="string">
          <text>eventRequest.applicationCode</text>
        </inputExpression>
      </input>
      <input id="_4fdc06e1" label="Event Name">
        <inputExpression id="_c6fca70c" typeRef="string">
          <text>eventRequest.eventName</text>
        </inputExpression>
      </input>
      <output id="_ded82641" name="eventMatch" typeRef="boolean"/>
      <rule id="_249e5556">
        <description>Match ANL OpenAccount event</description>
        <inputEntry id="_50e9e6ee">
          <text>"ANL"</text>
        </inputEntry>
        <inputEntry id="_f5b377ff">
          <text>"OpenAccount"</text>
        </inputEntry>
        <outputEntry id="_de443c21">
          <text>true</text>
        </outputEntry>
      </rule>
      <rule id="_276394b8">
        <description>No match for any other event</description>
        <inputEntry id="_b671584a">
          <text>-</text>
        </inputEntry>
        <inputEntry id="_3eafd3cd">
          <text>-</text>
        </inputEntry>
        <outputEntry id="_c3c1969e">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision id="decision_userProfileMatch" name="userProfileMatch">
    <variable id="var_userProfileMatch" name="userProfileMatch" typeRef="boolean"/>
    <informationRequirement id="_9c4e6975">
      <requiredInput href="#inputData_eventRequest"/>
    </informationRequirement>
    <decisionTable hitPolicy="FIRST" id="dt_userProfileMatch">
      <input id="_ef0e0e1b" label="Age">
        <inputExpression id="_5922eaaf" typeRef="number">
          <text>eventRequest.userProfile.age</text>
        </inputExpression>
      </input>
      <input id="_8fc9efc4" label="Account Type">
        <inputExpression id="_af525d71" typeRef="string">
          <text>eventRequest.userProfile.accountType</text>
        </inputExpression>
      </input>
      <input id="_0e2f3287" label="Segment Type">
        <inputExpression id="_4e0332d9" typeRef="string">
          <text>eventRequest.userProfile.segmentType</text>
        </inputExpression>
      </input>
      <output id="_84e26a98" name="userProfileMatch" typeRef="boolean"/>
      <rule id="_4b577029">
        <description>Advised OW account holder between 18 and 65</description>
        <inputEntry id="_f05027ed">
          <text>(18..65)</text>
        </inputEntry>
        <inputEntry id="_8e4363ea">
          <text>"OW"</text>
        </inputEntry>
        <inputEntry id="_5ea588c1">
          <text>"Advised"</text>
        </inputEntry>
        <outputEntry id="_b56d6779">
          <text>true</text>
        </outputEntry>
      </rule>
      <rule id="_f9b751e7">
        <description>No match for other profiles</description>
        <inputEntry id="_69f3df7e">
          <text>-</text>
        </inputEntry>
        <inputEntry id="_e6c1b646">
          <text>-</text>
        </inputEntry>
        <inputEntry id="_edc6574d">
          <text>-</text>
        </inputEntry>
        <outputEntry id="_d857336c">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision id="decision_Action_Decision" name="Action Decision">
    <variable id="var_Action_Decision" name="action" typeRef="string"/>
    <informationRequirement id="_b425ed13">
      <requiredDecision href="#decision_eventMatch"/>
    </informationRequirement>
    <informationRequirement id="_3dabd102">
      <requiredDecision href="#decision_userProfileMatch"/>
    </informationRequirement>
    <decisionTable hitPolicy="FIRST" id="dt_Action_Decision">
      <input id="_58cdc568" label="Event Match">
        <inputExpression id="_d360c8a9" typeRef="boolean">
          <text>eventMatch</text>
        </inputExpression>
      </input>
      <input id="_12b35752" label="User Profile Match">
        <inputExpression id="_3174e40e" typeRef="boolean">
          <text>userProfileMatch</text>
        </inputExpression>
      </input>
      <output id="_6fb26574" name="action" typeRef="string"/>
      <rule id="_7bd670d1">
        <description>Both event and profile match - send SMS</description>
        <inputEntry id="_50934d75">
          <text>true</text>
        </inputEntry>
        <inputEntry id="_9a45ccfc">
          <text>true</text>
        </inputEntry>
        <outputEntry id="_fd899b98">
          <text>"SendSMS"</text>
        </outputEntry>
      </rule>
      <rule id="_045de56e">
        <description>Any other combination - do not send</description>
        <inputEntry id="_24e6ac22">
          <text>-</text>
        </inputEntry>
        <inputEntry id="_2962acbb">
          <text>-</text>
        </inputEntry>
        <outputEntry id="_2e73510c">
          <text>"NoSend"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
